# Database
DATABASE_URL=postgresql://user:pass@host/roaddb?sslmode=require

# Backend
PORT=8080

# CORS (comma-separated origins allowed)
# Production: not needed — frontend + backend are same origin via Vercel experimentalServices
# Development: local Vite dev server calls local Go backend on different port
ALLOWED_ORIGINS=http://localhost:5173,https://who-built-this-road.vercel.app

# Frontend (Vite) — used in development via .env.local
# Vite proxy rewrites /api/* -> localhost:8080/* in dev (strips /api prefix).
# In production, Vercel edge strips /api before forwarding to the Go backend.
