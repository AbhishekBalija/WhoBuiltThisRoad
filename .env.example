# Database
DATABASE_URL=postgresql://user:pass@host/roaddb?sslmode=require

# Backend
PORT=8080
API_BASE_PATH=/api

# CORS (comma-separated origins allowed in development)
ALLOWED_ORIGINS=http://localhost:5173

# Frontend (Vite) — used in development via .env.local
# VITE_API_URL is not needed — Vite proxy handles /api -> localhost:8080 in dev,
# and same-origin in production via Vercel multi-service routing.
